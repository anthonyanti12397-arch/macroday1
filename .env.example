# ─── Database ────────────────────────────────────────────────────────────────
# Neon PostgreSQL — cloud database for user data sync
# Get yours at: https://neon.tech/
DATABASE_URL=postgresql://user:password@region.neon.tech/dbname?sslmode=require
DIRECT_URL=postgresql://user:password@region.neon.tech/dbname?sslmode=require

# ─── AI APIs ─────────────────────────────────────────────────────────────────
# xAI (Grok) — for meal plan generation
# Get yours at: https://console.x.ai/
XAI_API_KEY=

# Together AI — for food photo generation (FLUX model)
# Get yours at: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# Silicon Flow — for image generation
# Get yours at: https://cloud.siliconflow.cn/
SILICONFLOW_API_KEY=

# Anthropic — for Claude Vision API (food identification)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
