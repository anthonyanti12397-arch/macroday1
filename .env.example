# ─── Database ────────────────────────────────────────────────────────────────
# Neon PostgreSQL — cloud database for user data sync
# Get yours at: https://neon.tech/
DATABASE_URL=postgresql://user:password@region.neon.tech/dbname?sslmode=require
DIRECT_URL=postgresql://user:password@region.neon.tech/dbname?sslmode=require

# ─── Authentication ──────────────────────────────────────────────────────────
# NextAuth configuration
NEXTAUTH_SECRET=（generate: openssl rand -base64 32）
NEXTAUTH_URL=https://macroday1.vercel.app

# Google OAuth — for sign in with Google
# Get yours at: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth — for sign in with Apple
# Get yours at: https://developer.apple.com/account/resources/identifiers/list
# Note: Configure a Service ID with Sign in with Apple capability
# Set Redirect URL to: https://macroday1.vercel.app/api/auth/callback/apple
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ─── Stripe (Payment Processing) ──────────────────────────────────────────────
# Live keys for production payments
# Get yours at: https://dashboard.stripe.com/
STRIPE_SECRET_KEY=sk_live_... or sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_... or pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_... (from Stripe Dashboard → Webhooks)

# Stripe Product Price IDs (configure in Stripe Dashboard)
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_ADFREE_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_DONATE_PRICE_ID=price_...

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Email service for OTP and transactional emails
# Get yours at: https://resend.com/
RESEND_API_KEY=re_...

# ─── AI APIs ─────────────────────────────────────────────────────────────────
# xAI (Grok) — for meal plan generation
# Get yours at: https://console.x.ai/
XAI_API_KEY=

# Together AI — for food photo generation (FLUX model)
# Get yours at: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# Silicon Flow — for image generation
# Get yours at: https://cloud.siliconflow.cn/
SILICONFLOW_API_KEY=

# Anthropic — for Claude Vision API (food identification)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
