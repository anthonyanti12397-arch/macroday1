generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String           @id @default(cuid())
  email               String?          @unique
  name                String?
  image               String?
  provider            String           @default("email-otp")
  preferredCuisine    String?
  dietaryRestrictions Json?
  dislikedIngredients Json?
  isPro               Boolean          @default(false)
  isAdFree            Boolean          @default(false)
  autoGenerateDaily   Boolean          @default(false)
  goal                String?
  proTrialEndsAt      DateTime?
  streak              Int              @default(0)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  lastLogin           DateTime         @default(now())
  inbodyHistory       InBodyEntry[]
  mealPlans           MealPlan[]
  forumPosts          ForumPost[]
  forumReplies        ForumReply[]
  forumLikes          ForumLike[]
  promptFeedback      PromptFeedback[]
}

model InBodyEntry {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entryDate          String
  weight             Float
  height             Float
  gender             String
  age                Int
  bodyFat            Float?
  skeletalMuscleMass Float?
  bmr                Float?
  visceralFatLevel   Float?
  bodyWater          Float?
  createdAt          DateTime @default(now())

  @@index([userId, createdAt])
}

model MealPlan {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planType         String
  planDate         String?
  weekStart        String?
  payload          Json
  targetCalories   Int?
  targetProtein    Int?
  promptVersion    String   @default("v1")
  preferredCuisine String?
  source           String   @default("ai")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId, planType, createdAt])
}

model ForumPost {
  id               String      @id @default(cuid())
  userId           String
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  content          String      @db.Text
  mealImage        String?
  compliance       Int?
  streakSnapshot   Int?
  isCheckIn        Boolean     @default(false)
  likesCount       Int         @default(0)
  replyCount       Int         @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  replies          ForumReply[]
  likes            ForumLike[]

  @@index([userId, createdAt])
  @@index([createdAt])
}

model ForumReply {
  id        String    @id @default(cuid())
  postId    String
  userId    String
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String    @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([postId, createdAt])
}

model ForumLike {
  id        String    @id @default(cuid())
  postId    String
  userId    String
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([postId, userId])
  @@index([userId])
}

model PromptFeedback {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealPlanId         String?
  mealType           String?
  reason             String?
  dislikedIngredients Json?
  promptVersion      String   @default("v1")
  createdAt          DateTime @default(now())

  @@index([userId, createdAt])
}
