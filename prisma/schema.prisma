generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String           @id @default(cuid())
  email               String?          @unique
  name                String?
  image               String?
  provider            String           @default("email-otp")
  localState          Json?
  preferredCuisine    String?
  dietaryRestrictions Json?
  dislikedIngredients Json?
  isPro               Boolean          @default(false)
  isAdFree            Boolean          @default(false)
  autoGenerateDaily   Boolean          @default(false)
  goal                String?
  proTrialEndsAt      DateTime?
  proTrialCanceledAt  DateTime?
  streak              Int              @default(0)

  // Stripe subscription tracking
  stripeCustomerId    String?          @unique
  stripeSubscriptionId String?
  subscriptionStatus  String?          @default("free")

  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  lastLogin           DateTime         @default(now())
  authAccounts        AuthAccount[]
  inbodyHistory       InBodyEntry[]
  mealPlans           MealPlan[]
  forumPosts          ForumPost[]
  forumReplies        ForumReply[]
  forumLikes          ForumLike[]
  promptFeedback      PromptFeedback[]
  subscriptionHistory SubscriptionHistory[]
  invoices            Invoice[]
  sentFriendRequests  Friendship[]         @relation("FriendRequester")
  receivedFriendRequests Friendship[]      @relation("FriendAddressee")
  stepLogs            StepLog[]
}

model AuthAccount {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  providerAccountId String
  email             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model InBodyEntry {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entryDate          String
  weight             Float
  height             Float
  gender             String
  age                Int
  bodyFat            Float?
  skeletalMuscleMass Float?
  bmr                Float?
  visceralFatLevel   Float?
  bodyWater          Float?
  createdAt          DateTime @default(now())

  @@index([userId, createdAt])
}

model MealPlan {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planType         String
  planDate         String?
  weekStart        String?
  payload          Json
  targetCalories   Int?
  targetProtein    Int?
  promptVersion    String   @default("v1")
  preferredCuisine String?
  source           String   @default("ai")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId, planType, createdAt])
}

model ForumPost {
  id               String      @id @default(cuid())
  userId           String
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  content          String      @db.Text
  mealImage        String?
  compliance       Int?
  streakSnapshot   Int?
  isCheckIn        Boolean     @default(false)
  likesCount       Int         @default(0)
  replyCount       Int         @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  replies          ForumReply[]
  likes            ForumLike[]

  @@index([userId, createdAt])
  @@index([createdAt])
}

model ForumReply {
  id        String    @id @default(cuid())
  postId    String
  userId    String
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String    @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([postId, createdAt])
}

model ForumLike {
  id        String    @id @default(cuid())
  postId    String
  userId    String
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([postId, userId])
  @@index([userId])
}

model PromptFeedback {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealPlanId         String?
  mealType           String?
  reason             String?
  dislikedIngredients Json?
  promptVersion      String   @default("v1")
  createdAt          DateTime @default(now())

  @@index([userId, createdAt])
}

// Friend system
model Friendship {
  id         String   @id @default(cuid())
  requesterId String
  addresseeId String
  status     String   @default("pending") // pending|accepted|blocked
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  requester  User     @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee  User     @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([requesterId, status])
  @@index([addresseeId, status])
}

// Step tracking
model StepLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String   // YYYY-MM-DD
  steps     Int
  source    String   @default("manual") // manual|healthkit|googlefit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

model SubscriptionHistory {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromPlan     String   // free|pro|adfree
  toPlan       String   // free|pro|adfree
  stripeEventId String?  @unique
  timestamp    DateTime @default(now())

  @@index([userId, timestamp])
}

model Invoice {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeInvoiceId String   @unique
  amount          Int      // cents
  currency        String
  status          String   // draft|open|paid|uncollectible|void
  dueDate         DateTime?
  paidAt          DateTime?
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, createdAt])
}
